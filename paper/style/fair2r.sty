% =====================================================================
% fair2r.sty — F(AI^2)R paper style, aligned with the DLR Corporate
% Design (CD-Handbuch §10.1, §4 Printmedien).
%
% - Body face: Helvetica/Arial-equivalent (helvet) per CD-Handbuch §10.1
%   "Elektronischer Dokumentenaustausch ... Arial".
% - Accent: DLR Blue #00658B (default).
% - Section headings: mid-grey #666 (H1) and DLR Blue (H2).
% - Square corners (DLR layout rule, 0–2px max).
% - Hairline rules in tables; no shadows.
%
% Variant: blue is the default. To switch chapter accent in the paper,
% set \faiarVariant before \usepackage{style/fair2r} -- e.g.
% \def\faiarVariant{b} (green) or \def\faiarVariant{c} (yellow).
%
% Set \faiarDraft to "true" before \usepackage to render a "DRAFT --
% not yet peer-reviewed" watermark on every page.
% =====================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{fair2r}[2026/05/06 F(AI^2)R DLR-aligned style]

% --- Defaults that the document may override BEFORE \usepackage -------
\providecommand{\faiarVariant}{a}
\providecommand{\faiarDraft}{false}

\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}
\RequirePackage{textcomp}
\RequirePackage{amsmath}     % \text{} inside math mode (used by figures/hero.tex)
\RequirePackage[scaled=1.0]{helvet}
\renewcommand{\familydefault}{\sfdefault}

\RequirePackage{microtype}
\RequirePackage{xcolor}
\RequirePackage{colortbl}
\RequirePackage{booktabs}
\RequirePackage{array}
\RequirePackage{tabularx}
\RequirePackage{longtable}
\RequirePackage{enumitem}
\RequirePackage{titlesec}
\RequirePackage{titling}
\RequirePackage[margin=2.5cm,headheight=14pt]{geometry}
\RequirePackage{fancyhdr}
\RequirePackage{caption}
\RequirePackage[hidelinks]{hyperref}
\RequirePackage{ifthen}
\RequirePackage{draftwatermark}
\RequirePackage{tikz}
\usetikzlibrary{arrows.meta, positioning, shapes.geometric, calc, fit}

% --- DLR colour ramps (subset; expand as needed) -----------------------
\definecolor{dlrBlau1}{HTML}{00658B}
\definecolor{dlrBlau2}{HTML}{3B98CB}
\definecolor{dlrBlau5}{HTML}{D1E8FA}
\definecolor{dlrGruen1}{HTML}{82A043}
\definecolor{dlrGruen5}{HTML}{E6EAAF}
\definecolor{dlrGelb1}{HTML}{D2AE3D}
\definecolor{dlrGelb5}{HTML}{FFF8BE}
\definecolor{dlrGrau1}{HTML}{666666}
\definecolor{dlrGrau3}{HTML}{B1B1B1}
\definecolor{dlrGrau4}{HTML}{CFCFCF}
\definecolor{dlrGrau5}{HTML}{EBEBEB}
\definecolor{dlrLink}{HTML}{00B0F0}
\definecolor{dlrLogo}{HTML}{1D1D1B}

% --- Active accent per chosen variant ----------------------------------
\ifthenelse{\equal{\faiarVariant}{b}}{%
  \colorlet{dlrAccent}{dlrGruen1}\colorlet{dlrAccentSoft}{dlrGruen5}%
}{}
\ifthenelse{\equal{\faiarVariant}{c}}{%
  \colorlet{dlrAccent}{dlrGelb1}\colorlet{dlrAccentSoft}{dlrGelb5}%
}{}
\ifthenelse{\equal{\faiarVariant}{a}}{%
  \colorlet{dlrAccent}{dlrBlau1}\colorlet{dlrAccentSoft}{dlrBlau5}%
}{}
% Fallback if user set \faiarVariant to something unexpected.
\providecolor{dlrAccent}{HTML}{00658B}
\providecolor{dlrAccentSoft}{HTML}{D1E8FA}

\hypersetup{
  colorlinks=true,
  linkcolor=dlrAccent,
  citecolor=dlrAccent,
  urlcolor=dlrLink,
}

% --- Sectioning: H1 mid-grey, H2/H3 in accent --------------------------
\titleformat{\section}
  {\sffamily\bfseries\Large\color{dlrGrau1}}
  {\thesection}{0.6em}{}
\titleformat{\subsection}
  {\sffamily\bfseries\large\color{dlrAccent}}
  {\thesubsection}{0.55em}{}
\titleformat{\subsubsection}
  {\sffamily\bfseries\normalsize\color{dlrGrau1}}
  {\thesubsubsection}{0.5em}{}
\titlespacing*{\section}{0pt}{1.4\baselineskip}{0.6\baselineskip}
\titlespacing*{\subsection}{0pt}{1.0\baselineskip}{0.4\baselineskip}

% --- Title block: minimal, left-aligned, with DLR-Blue rule under -----
\pretitle{\noindent\sffamily\bfseries\Huge\color{dlrGrau1}}
\posttitle{\par\vspace{0.4em}{\color{dlrAccent}\rule{\linewidth}{1.2pt}}\par\vspace{0.4em}}
\preauthor{\noindent\sffamily\normalsize\color{black}\begin{tabular}[t]{@{}l@{}}}
\postauthor{\end{tabular}\par}
\predate{\noindent\sffamily\small\color{dlrGrau1}}
\postdate{\par\vspace{0.6em}}

% --- Page style: hairline rules, page number in grey -------------------
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}
\fancyhead[R]{\sffamily\footnotesize\color{dlrGrau1}F(AI)\textsuperscript{2}R}
\fancyfoot[R]{\sffamily\footnotesize\color{dlrGrau1}\thepage}
% Title page uses plain style, but we want the same look there too.
\fancypagestyle{plain}{%
  \fancyhf{}%
  \fancyfoot[R]{\sffamily\footnotesize\color{dlrGrau1}\thepage}%
  \renewcommand{\headrulewidth}{0pt}%
  \renewcommand{\footrulewidth}{0pt}%
}

% --- Captions: small, mid-grey -----------------------------------------
\captionsetup{font={small,sf,color=dlrGrau1},labelfont=bf,labelsep=period}

% --- Tables: hairline rules ---------------------------------------------
\setlength{\heavyrulewidth}{0.6pt}
\setlength{\lightrulewidth}{0.3pt}
\setlength{\cmidrulewidth}{0.3pt}
\arrayrulecolor{dlrGrau4}

% --- Lists: tight, accent for first level ------------------------------
\setlist[itemize,1]{leftmargin=1.4em,itemsep=2pt,topsep=4pt,
                    label=\textcolor{dlrAccent}{\textbullet}}
\setlist[itemize,2]{leftmargin=1.0em,itemsep=2pt,topsep=2pt,label=--}
\setlist[enumerate,1]{leftmargin=1.6em,itemsep=2pt,topsep=4pt,
                      label=\textcolor{dlrAccent}{\arabic*.}}
\setlist[description]{leftmargin=1.2em,itemsep=2pt,topsep=4pt,
                      font=\sffamily\bfseries\color{dlrGrau1}}

% --- DRAFT watermark, opt-in ------------------------------------------
\ifthenelse{\equal{\faiarDraft}{true}}{%
  \SetWatermarkText{DRAFT \textendash{} not yet peer-reviewed}%
  \SetWatermarkScale{0.45}%
  \SetWatermarkColor[gray]{0.88}%
  \SetWatermarkAngle{55}%
}{}

% --- Convenience macros -----------------------------------------------
\newcommand{\faiar}{F(AI)\textsuperscript{2}R}

\endinput
