#-------------------------------------------------------------------------
# New claim: domain ontologies as schema extension (researcher-proposed)
#-------------------------------------------------------------------------

src:janowicz2019sosa           a fair2r:Source ;
    dcterms:title "SOSA: A lightweight ontology for sensors, observations, samples, and actuators"@en ;
    dcterms:identifier "doi:10.1016/j.websem.2018.06.003" ;
    fair2r:verificationState verif:lit-retrieved .

src:rijgersberg2013om          a fair2r:Source ;
    dcterms:title "Ontology of units of Measure and related concepts"@en ;
    dcterms:identifier "doi:10.3233/SW-2012-0069" ;
    fair2r:verificationState verif:lit-retrieved .

src:qudt                       a fair2r:Source ;
    dcterms:title "QUDT: Quantities, Units, Dimensions and Types ontology"@en ;
    dcterms:identifier <https://www.qudt.org/> ;
    fair2r:verificationState verif:lit-retrieved .

ent:section-pattern-domain-ontologies  a fair2r:Section ;
    rdfs:label "Extensibility through domain ontologies"@en ;
    prov:hadPrimarySource ent:manuscript .

claim:domain-ontologies-extension  a fair2r:Claim ;
    rdfs:label "Domain ontologies (SOSA / SSN for sensor data, OM-2 / QUDT for units of measure) plug into the F(AI)^2R schema as side-arms of PROV-O, grounding the values of claims (not just their evidence) in machine-checkable terms; this addresses unit-and-dimension defects that prose alone cannot reach, and is a low-cost win for engineering and metadata communities (NFDI4Ing, HMC) that already maintain such ontologies."@en ;
    prov:wasAttributedTo agent:human-author ;
    prov:wasDerivedFrom  src:janowicz2019sosa , src:rijgersberg2013om , src:qudt ;
    fair2r:verificationState verif:human-confirmed ;
    dcterms:created "2026-05-06"^^xsd:date .

act:rev-domain-ontologies      a prov:Activity ;
    rdfs:label "Add §3.5 'Extensibility through domain ontologies' to pattern.tex"@en ;
    prov:startedAtTime "2026-05-06T00:00:00Z"^^xsd:dateTime ;
    prov:endedAtTime   "2026-05-06T00:00:00Z"^^xsd:dateTime ;
    prov:wasAssociatedWith agent:claude-opus-4-7 ;
    prov:wasAssociatedWith agent:human-author ;
    prov:used src:janowicz2019sosa , src:rijgersberg2013om , src:qudt .

ent:section-pattern-domain-ontologies  prov:wasGeneratedBy act:rev-domain-ontologies ;
                                       prov:wasAttributedTo agent:scientific-writer , agent:human-author .

hc:domain-ontologies           a fair2r:HumanContribution ;
    rdfs:label "Researcher claim: domain ontologies (SOSA, OM-2, QUDT) extend the schema"@en ;
    fair2r:contributedBy agent:human-author ;
    fair2r:contributionType "content-prompt" ;
    fair2r:contributionLeverage "high" ;
    rdfs:comment "Researcher proposed during session: 'ontologies might actually help to make this process more efficient and reproducible (first example prov, but for example sensor data and OM-2 (units of measure) ontology --- konkrete standardisierte methoden ... potential)'. Claim graduated to paper text in §3.5 of pattern.tex; bibliography gains janowicz2019sosa, rijgersberg2013om, qudt; the German phrase 'konkrete standardisierte Methode' carried into the prose as a load-bearing technical term in the source-author voice."@en ;
    dcterms:created "2026-05-06"^^xsd:date ;
    prov:influenced ent:section-pattern-domain-ontologies ,
                    claim:domain-ontologies-extension .

