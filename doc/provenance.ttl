#-------------------------------------------------------------------------
# Schema extension: Contribution
#-------------------------------------------------------------------------
# A discrete shaping intervention by an agent (human or AI) on the
# manuscript or its scaffolding. Contribution is finer-grained than
# prov:Activity (one Activity may contain many Contributions) and
# coarser than prov:wasGeneratedBy / prov:wasAttributedTo (one
# Contribution typically generates several entities and is attributed
# to one agent). Made explicit so the question "what did the human
# actually do here?" --- and the symmetric question for the AI --- has
# a structured, queryable answer.

fair2r:Contribution        a owl:Class ; rdfs:subClassOf prov:Activity ;
    rdfs:label "Contribution"@en ;
    rdfs:comment "A discrete shaping intervention by an agent on the manuscript or its scaffolding."@en .
fair2r:HumanContribution   a owl:Class ; rdfs:subClassOf fair2r:Contribution ;
    rdfs:label "Human contribution"@en .
fair2r:AIContribution      a owl:Class ; rdfs:subClassOf fair2r:Contribution ;
    rdfs:label "AI contribution"@en .
fair2r:MetaContribution    a owl:Class ; rdfs:subClassOf fair2r:Contribution ;
    rdfs:label "Meta contribution (an observation about the cooperation itself)"@en .

# Properties on a Contribution
fair2r:contributionType  a owl:DatatypeProperty ;
    rdfs:domain fair2r:Contribution ; rdfs:range xsd:string ;
    rdfs:comment "structural-decision | corrective-intervention | content-prompt | rule-shape | observation | responsibility-uptake | experience-meta"@en .
fair2r:contributionLeverage  a owl:DatatypeProperty ;
    rdfs:domain fair2r:Contribution ; rdfs:range xsd:string ;
    rdfs:comment "high | medium | low --- how much subsequent work the contribution redirected."@en .
fair2r:promotedToPaper  a owl:DatatypeProperty ;
    rdfs:domain fair2r:MetaContribution ; rdfs:range xsd:string ;
    rdfs:comment "yes | pending | no --- whether the observation graduated to paper text."@en .

#-------------------------------------------------------------------------
# Back-filled HumanContribution instances (mirror of doc/user-contributions.md)
# Keep this block append-only; one entry per documented contribution.
#-------------------------------------------------------------------------

