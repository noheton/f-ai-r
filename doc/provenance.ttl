@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf:    <http://xmlns.com/foaf/0.1/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .

# Project namespaces
@prefix fair2r:  <https://noheton.org/f-ai-r/ns#> .
@prefix agent:   <https://noheton.org/f-ai-r/agent/> .
@prefix act:     <https://noheton.org/f-ai-r/activity/> .
@prefix ent:     <https://noheton.org/f-ai-r/entity/> .
@prefix claim:   <https://noheton.org/f-ai-r/claim/> .
@prefix src:     <https://noheton.org/f-ai-r/source/> .
@prefix verif:   <https://noheton.org/f-ai-r/verification/> .

#-------------------------------------------------------------------------
# Vocabulary: F(AI^2)R extensions to PROV-O
#-------------------------------------------------------------------------

fair2r:AIAgent          a owl:Class ; rdfs:subClassOf prov:SoftwareAgent ;
    rdfs:label "AI agent"@en ;
    rdfs:comment "An LLM-driven agent participating in the writing pipeline."@en .

fair2r:HumanResearcher  a owl:Class ; rdfs:subClassOf prov:Person ;
    rdfs:label "Human researcher"@en .

fair2r:Claim            a owl:Class ; rdfs:subClassOf prov:Entity ;
    rdfs:label "Claim"@en ;
    rdfs:comment "An assertion made in the manuscript that warrants attribution."@en .

fair2r:Source           a owl:Class ; rdfs:subClassOf prov:Entity ;
    rdfs:label "Source"@en .

fair2r:Manuscript       a owl:Class ; rdfs:subClassOf prov:Entity ;
    rdfs:label "Manuscript"@en .

fair2r:Section          a owl:Class ; rdfs:subClassOf prov:Entity .
fair2r:Transcript       a owl:Class ; rdfs:subClassOf prov:Entity ;
    rdfs:label "Conversation transcript binding a working session to the manuscript via prov:used; carrier of the first integrated practice (transcript preservation)."@en .
fair2r:Figure           a owl:Class ; rdfs:subClassOf prov:Entity .
fair2r:Prompt           a owl:Class ; rdfs:subClassOf prov:Plan .
fair2r:Build            a owl:Class ; rdfs:subClassOf prov:Activity .
fair2r:AuthoringPass    a owl:Class ; rdfs:subClassOf prov:Activity .
fair2r:AuditPass        a owl:Class ; rdfs:subClassOf prov:Activity .

fair2r:verificationState a owl:ObjectProperty ;
    rdfs:domain fair2r:Claim ;
    rdfs:range  fair2r:VerificationState .

fair2r:VerificationState a owl:Class .
fair2r:contradicts       a owl:ObjectProperty ;
    rdfs:domain fair2r:Claim ; rdfs:range fair2r:Claim .

# Repair edges: an activity that fixes a structural defect on a claim
# (e.g. backfilling a missing prov:wasGeneratedBy edge surfaced by the
# SPARQL conformance query). Lighter than a prov:Invalidation: the
# claim's content stands; only the metadata about how it was generated
# is being amended. Schema growth is explicit per the curator rule.
fair2r:repairs           a owl:ObjectProperty ;
    rdfs:domain prov:Activity ; rdfs:range fair2r:Claim ;
    rdfs:label "repairs"@en ;
    rdfs:comment "Object property linking a repair activity to the claim whose provenance metadata it is amending."@en .

# Verification ladder (rungs as individuals)
verif:unverified       a fair2r:VerificationState ; rdfs:label "unverified"@en .
verif:needs-research   a fair2r:VerificationState ; rdfs:label "needs research"@en .
verif:lit-retrieved    a fair2r:VerificationState ; rdfs:label "lit-retrieved"@en .
verif:ai-confirmed     a fair2r:VerificationState ; rdfs:label "AI-confirmed"@en .
verif:human-confirmed  a fair2r:VerificationState ; rdfs:label "human-confirmed"@en .
verif:source-vendored  a fair2r:VerificationState ; rdfs:label "source vendored"@en .
verif:lit-read         a fair2r:VerificationState ; rdfs:label "lit-read"@en .

#-------------------------------------------------------------------------
# Agents
#-------------------------------------------------------------------------

agent:human-author       a fair2r:HumanResearcher ;
    foaf:name "TBD" ;
    rdfs:comment "Placeholder; replace with ORCID-bearing author records." .

agent:claude-opus-4-7    a fair2r:AIAgent ;
    foaf:name "Claude Opus 4.7" ;
    rdfs:comment "Anthropic LLM, invoked via Claude Code." .

agent:claude-sonnet-4-6  a fair2r:AIAgent ;
    foaf:name "Claude Sonnet 4.6" ;
    rdfs:comment "Anthropic LLM, invoked via Claude Code." .

agent:orchestrator       a fair2r:AIAgent ;
    foaf:name "Orchestrator" ;
    prov:actedOnBehalfOf agent:human-author .

agent:scientific-writer  a fair2r:AIAgent ;
    foaf:name "Scientific Writer" ;
    prov:actedOnBehalfOf agent:human-author .

agent:source-analyzer    a fair2r:AIAgent ;
    foaf:name "Source Analyzer" ;
    prov:actedOnBehalfOf agent:human-author .

agent:fair-aligner       a fair2r:AIAgent ;
    foaf:name "FAIR Aligner" ;
    prov:actedOnBehalfOf agent:human-author .

agent:provenance-curator a fair2r:AIAgent ;
    foaf:name "Provenance Curator" ;
    prov:actedOnBehalfOf agent:human-author .

agent:layout-scrutinizer a fair2r:AIAgent ;
    foaf:name "Layout Scrutinizer" ;
    prov:actedOnBehalfOf agent:human-author .

agent:readability-reviewer a fair2r:AIAgent ;
    foaf:name "Readability Reviewer" ;
    prov:actedOnBehalfOf agent:human-author .

agent:illustration       a fair2r:AIAgent ;
    foaf:name "Illustration" ;
    prov:actedOnBehalfOf agent:human-author .

agent:condenser          a fair2r:AIAgent ;
    foaf:name "Condenser" ;
    prov:actedOnBehalfOf agent:human-author .

agent:research-protocol  a fair2r:AIAgent ;
    foaf:name "Research Protocol" ;
    prov:actedOnBehalfOf agent:human-author .

#-------------------------------------------------------------------------
# Plans (the prompts in agents/ are PROV-O Plans)
#-------------------------------------------------------------------------

ent:prompt-orchestrator        a fair2r:Prompt ; dcterms:source <agents/orchestrator.md> .
ent:prompt-scientific-writer   a fair2r:Prompt ; dcterms:source <agents/scientific-writer.md> .
ent:prompt-source-analyzer     a fair2r:Prompt ; dcterms:source <agents/source-analyzer.md> .
ent:prompt-fair-aligner        a fair2r:Prompt ; dcterms:source <agents/fair-aligner.md> .
ent:prompt-provenance-curator  a fair2r:Prompt ; dcterms:source <agents/provenance-curator.md> .
ent:prompt-layout-scrutinizer  a fair2r:Prompt ; dcterms:source <agents/layout-scrutinizer.md> .
ent:prompt-readability-reviewer a fair2r:Prompt ; dcterms:source <agents/readability-reviewer.md> .
ent:prompt-illustration        a fair2r:Prompt ; dcterms:source <agents/illustration.md> .
ent:prompt-condenser           a fair2r:Prompt ; dcterms:source <agents/condenser.md> .
ent:prompt-research-protocol   a fair2r:Prompt ; dcterms:source <agents/research-protocol.md> .

#-------------------------------------------------------------------------
# The manuscript and its parts (entities)
#-------------------------------------------------------------------------

ent:manuscript            a fair2r:Manuscript ;
    rdfs:label "F(AI^2)R manuscript (long form)"@en ;
    dcterms:source <paper/main.tex> .

ent:manuscript-condensed  a fair2r:Manuscript ;
    rdfs:label "F(AI^2)R manuscript (condensed)"@en ;
    dcterms:source <paper/main-condensed.tex> .

ent:section-intro         a fair2r:Section ; rdfs:label "Introduction"@en ;
    prov:hadPrimarySource ent:manuscript .
ent:section-background    a fair2r:Section ; rdfs:label "Background"@en ;
    prov:hadPrimarySource ent:manuscript .
ent:section-pattern       a fair2r:Section ; rdfs:label "The F(AI^2)R Pattern"@en ;
    prov:hadPrimarySource ent:manuscript .
ent:section-impl          a fair2r:Section ; rdfs:label "Implementation"@en ;
    prov:hadPrimarySource ent:manuscript .
ent:section-discussion    a fair2r:Section ; rdfs:label "Discussion"@en ;
    prov:hadPrimarySource ent:manuscript .
ent:section-related       a fair2r:Section ; rdfs:label "Related Work"@en ;
    prov:hadPrimarySource ent:manuscript .
ent:section-conclusion    a fair2r:Section ; rdfs:label "Conclusion"@en ;
    prov:hadPrimarySource ent:manuscript .

#-------------------------------------------------------------------------
# Sources cited (entities)
#-------------------------------------------------------------------------

src:wilkinson2016fair  a fair2r:Source ;
    dcterms:title "The FAIR Guiding Principles for scientific data management and stewardship"@en ;
    dcterms:identifier "doi:10.1038/sdata.2016.18" ;
    dcterms:date "2016-03-15"^^xsd:date ;
    fair2r:verificationState verif:ai-confirmed .

src:w3c2013provo  a fair2r:Source ;
    dcterms:title "PROV-O: The PROV Ontology"@en ;
    dcterms:identifier <https://www.w3.org/TR/prov-o/> ;
    dcterms:date "2013-04-30"^^xsd:date .

#-------------------------------------------------------------------------
# Activities — the creation of the paper, narrated as PROV
#-------------------------------------------------------------------------

# 1. Repository bootstrap
act:bootstrap  a prov:Activity ;
    rdfs:label "Bootstrap the F(AI^2)R repository"@en ;
    prov:startedAtTime "2026-05-06T00:00:00Z"^^xsd:dateTime ;
    prov:endedAtTime   "2026-05-06T00:00:00Z"^^xsd:dateTime ;
    prov:wasAssociatedWith agent:claude-opus-4-7 ;
    prov:wasAssociatedWith agent:human-author ;
    prov:used src:wilkinson2016fair , src:w3c2013provo .

ent:manuscript            prov:wasGeneratedBy   act:bootstrap ;
                          prov:wasAttributedTo  agent:claude-opus-4-7 ,
                                                agent:human-author ;
                          dcterms:created       "2026-05-06"^^xsd:date .

ent:manuscript-condensed  prov:wasGeneratedBy   act:bootstrap ;
                          prov:wasAttributedTo  agent:claude-opus-4-7 ,
                                                agent:human-author ;
                          dcterms:created       "2026-05-06"^^xsd:date .

# 2. Authoring pass — placeholder activity, one per section
act:author-intro  a fair2r:AuthoringPass ;
    rdfs:label "Draft the introduction"@en ;
    prov:wasAssociatedWith agent:scientific-writer ;
    prov:qualifiedAssociation [
        a prov:Association ;
        prov:agent agent:scientific-writer ;
        prov:hadPlan ent:prompt-scientific-writer
    ] ;
    prov:used src:wilkinson2016fair .

ent:section-intro         prov:wasGeneratedBy  act:author-intro ;
                          prov:wasAttributedTo agent:scientific-writer ,
                                               agent:human-author .

# 3. Audit pass — placeholder activities
act:audit-fair  a fair2r:AuditPass ;
    rdfs:label "FAIR alignment audit"@en ;
    prov:wasAssociatedWith agent:fair-aligner ;
    prov:qualifiedAssociation [
        a prov:Association ;
        prov:agent agent:fair-aligner ;
        prov:hadPlan ent:prompt-fair-aligner
    ] .

act:audit-layout  a fair2r:AuditPass ;
    rdfs:label "Layout audit"@en ;
    prov:wasAssociatedWith agent:layout-scrutinizer ;
    prov:qualifiedAssociation [
        a prov:Association ;
        prov:agent agent:layout-scrutinizer ;
        prov:hadPlan ent:prompt-layout-scrutinizer
    ] .

act:audit-readability  a fair2r:AuditPass ;
    rdfs:label "Readability audit"@en ;
    prov:wasAssociatedWith agent:readability-reviewer ;
    prov:qualifiedAssociation [
        a prov:Association ;
        prov:agent agent:readability-reviewer ;
        prov:hadPlan ent:prompt-readability-reviewer
    ] .

# 4. Provenance curation — the one activity that may write to this file
act:curate-provenance  a prov:Activity ;
    rdfs:label "Curate the provenance graph"@en ;
    prov:wasAssociatedWith agent:provenance-curator ;
    prov:qualifiedAssociation [
        a prov:Association ;
        prov:agent agent:provenance-curator ;
        prov:hadPlan ent:prompt-provenance-curator
    ] ;
    prov:generated <doc/provenance.ttl> .

# 5. Build — the PDF is itself an entity with provenance
act:build-pdf  a fair2r:Build ;
    rdfs:label "Compile the long-form PDF via latexmk"@en ;
    prov:used ent:manuscript .

ent:pdf-long  a prov:Entity ;
    rdfs:label "Compiled long-form PDF"@en ;
    prov:wasGeneratedBy act:build-pdf ;
    prov:wasDerivedFrom ent:manuscript .

#-------------------------------------------------------------------------
# Seed claims — the contribution claims of the paper
# These are stubs. As sections are drafted, scientific-writer proposes
# additional fair2r:Claim entities; provenance-curator validates and adds.
#-------------------------------------------------------------------------

claim:fair-needs-second-ai  a fair2r:Claim ;
    rdfs:label "FAIR needs a second AI pass — auditing — to remain meaningful in the LLM era."@en ;
    prov:wasAttributedTo agent:human-author ;
    prov:wasGeneratedBy  act:author-intro ;
    fair2r:verificationState verif:needs-research ;
    dcterms:created "2026-05-06"^^xsd:date .

claim:provenance-as-spine  a fair2r:Claim ;
    rdfs:label "A PROV-O graph that ships with the manuscript is the simplest viable spine for AI-mediated scholarly attribution."@en ;
    prov:wasAttributedTo agent:human-author ;
    prov:wasGeneratedBy  act:author-intro ;
    fair2r:verificationState verif:needs-research ;
    dcterms:created "2026-05-06"^^xsd:date .

claim:two-passes  a fair2r:Claim ;
    rdfs:label "AI participates twice in the F(AI^2)R loop: once as assistant in authoring, once as auditor of provenance."@en ;
    prov:wasAttributedTo agent:human-author ;
    prov:wasGeneratedBy  act:author-intro ;
    fair2r:verificationState verif:human-confirmed ;
    dcterms:created "2026-05-06"^^xsd:date .

#-------------------------------------------------------------------------
# Revision: primary-artifact consistency rule added to all prompts
#-------------------------------------------------------------------------

act:rev-consistency-rule  a prov:Activity ;
    rdfs:label "Add primary-artifact consistency invariant to all prompts"@en ;
    prov:startedAtTime "2026-05-06T00:00:00Z"^^xsd:dateTime ;
    prov:endedAtTime   "2026-05-06T00:00:00Z"^^xsd:dateTime ;
    prov:wasAssociatedWith agent:claude-opus-4-7 ;
    prov:wasAssociatedWith agent:human-author .

ent:prompt-orchestrator         prov:wasRevisionOf ent:prompt-orchestrator ;
                                prov:wasGeneratedBy act:rev-consistency-rule .
ent:prompt-scientific-writer    prov:wasRevisionOf ent:prompt-scientific-writer ;
                                prov:wasGeneratedBy act:rev-consistency-rule .
ent:prompt-source-analyzer      prov:wasRevisionOf ent:prompt-source-analyzer ;
                                prov:wasGeneratedBy act:rev-consistency-rule .
ent:prompt-fair-aligner         prov:wasRevisionOf ent:prompt-fair-aligner ;
                                prov:wasGeneratedBy act:rev-consistency-rule .
ent:prompt-provenance-curator   prov:wasRevisionOf ent:prompt-provenance-curator ;
                                prov:wasGeneratedBy act:rev-consistency-rule .
ent:prompt-layout-scrutinizer   prov:wasRevisionOf ent:prompt-layout-scrutinizer ;
                                prov:wasGeneratedBy act:rev-consistency-rule .
ent:prompt-readability-reviewer prov:wasRevisionOf ent:prompt-readability-reviewer ;
                                prov:wasGeneratedBy act:rev-consistency-rule .
ent:prompt-illustration         prov:wasRevisionOf ent:prompt-illustration ;
                                prov:wasGeneratedBy act:rev-consistency-rule .
ent:prompt-condenser            prov:wasRevisionOf ent:prompt-condenser ;
                                prov:wasGeneratedBy act:rev-consistency-rule .
ent:prompt-research-protocol    prov:wasRevisionOf ent:prompt-research-protocol ;
                                prov:wasGeneratedBy act:rev-consistency-rule .

claim:primary-artifact-invariant  a fair2r:Claim ;
    rdfs:label "The manuscript, the PROV-O graph, and the logbook are primary artifacts and must remain consistent and up to date at all times."@en ;
    prov:wasAttributedTo agent:human-author ;
    prov:wasGeneratedBy  act:rev-consistency-rule ;
    fair2r:verificationState verif:human-confirmed ;
    dcterms:created "2026-05-06"^^xsd:date .

#-------------------------------------------------------------------------
# Revision: site builder + Pages workflow + paper-build CI
#-------------------------------------------------------------------------

ent:script-build-provenance-site  a prov:Entity ;
    rdfs:label "scripts/build_provenance_site.py"@en ;
    dcterms:source <scripts/build_provenance_site.py> .

ent:workflow-pages   a prov:Entity ;
    rdfs:label ".github/workflows/pages.yml"@en ;
    dcterms:source <.github/workflows/pages.yml> .

ent:workflow-build-paper  a prov:Entity ;
    rdfs:label ".github/workflows/build-paper.yml"@en ;
    dcterms:source <.github/workflows/build-paper.yml> .

act:rev-site-and-ci  a prov:Activity ;
    rdfs:label "Add static-site builder, Pages workflow, paper-build CI"@en ;
    prov:startedAtTime "2026-05-06T00:00:00Z"^^xsd:dateTime ;
    prov:endedAtTime   "2026-05-06T00:00:00Z"^^xsd:dateTime ;
    prov:wasAssociatedWith agent:claude-opus-4-7 ;
    prov:wasAssociatedWith agent:human-author ;
    prov:generated ent:script-build-provenance-site ,
                   ent:workflow-pages ,
                   ent:workflow-build-paper .

ent:script-build-provenance-site  prov:wasGeneratedBy act:rev-site-and-ci ;
                                  prov:used ent:manuscript ,
                                            <doc/provenance.ttl> .
ent:workflow-pages                prov:wasGeneratedBy act:rev-site-and-ci .
ent:workflow-build-paper          prov:wasGeneratedBy act:rev-site-and-ci ;
                                  prov:used ent:manuscript ,
                                            ent:manuscript-condensed .

#-------------------------------------------------------------------------
# Revision: first-draft manuscript distilled from Obscurity-Is-Dead
#-------------------------------------------------------------------------

src:krebs2026obscurity  a fair2r:Source ;
    dcterms:title "Obscurity Is Dead: a methodology repository"@en ;
    dcterms:identifier <https://github.com/noheton/Obscurity-Is-Dead> ;
    dcterms:creator agent:human-author ;
    rdfs:comment "Methodological ancestor of the present paper; same author. Domain content abstracted away."@en ;
    fair2r:verificationState verif:source-vendored .

src:chuehong2022fair4rs  a fair2r:Source ;
    dcterms:title "FAIR Principles for Research Software (FAIR4RS Principles)"@en ;
    dcterms:identifier "doi:10.15497/RDA00068" ;
    fair2r:verificationState verif:ai-confirmed .

src:ravi2024fair4ml  a fair2r:Source ;
    dcterms:title "FAIR4ML-schema, version 0.1.0"@en ;
    dcterms:creator "Leyla Jael Castro" , "Daniel Garijo" , "RDA FAIR for Machine Learning Working Group" ;
    dcterms:identifier "doi:10.5281/zenodo.14002310" ;
    fair2r:verificationState verif:ai-confirmed ;
    rdfs:comment "Schema.org extension for FAIR ML models, output of the RDA FAIR4ML Interest Group; cited five times in the prose as the canonical FAIR4ML reference. Source IRI minted during the 2026-05-07 complete-loop FAIR-aligner audit (first defect named: 'load-bearing FAIR4ML cite has bib entry but no fair2r:Source triple in the graph'). Bibkey kept stable; rung at ai-confirmed pending human read."@en .

src:gebru2021datasheets  a fair2r:Source ;
    dcterms:title "Datasheets for Datasets"@en ;
    dcterms:identifier "doi:10.1145/3458723" ;
    fair2r:verificationState verif:ai-confirmed .

src:mitchell2019modelcards  a fair2r:Source ;
    dcterms:title "Model Cards for Model Reporting"@en ;
    dcterms:identifier "doi:10.1145/3287560.3287596" ;
    fair2r:verificationState verif:ai-confirmed .

src:page2021prisma  a fair2r:Source ;
    dcterms:title "The PRISMA 2020 statement"@en ;
    dcterms:identifier "doi:10.1136/bmj.n71" ;
    fair2r:verificationState verif:ai-confirmed .

src:guyatt2008grade  a fair2r:Source ;
    dcterms:title "GRADE: an emerging consensus on rating quality of evidence"@en ;
    dcterms:identifier "doi:10.1136/bmj.39489.470347.AD" ;
    fair2r:verificationState verif:ai-confirmed .

src:icmje2023  a fair2r:Source ;
    dcterms:title "ICMJE Recommendations 2023"@en ;
    dcterms:identifier <https://www.icmje.org/recommendations/> ;
    fair2r:verificationState verif:ai-confirmed .

src:bender2021stochastic  a fair2r:Source ;
    dcterms:title "On the Dangers of Stochastic Parrots"@en ;
    dcterms:identifier "doi:10.1145/3442188.3445922" ;
    fair2r:verificationState verif:ai-confirmed .

src:walters2023fabrication  a fair2r:Source ;
    dcterms:title "Fabrication and errors in the bibliographic citations generated by ChatGPT"@en ;
    dcterms:identifier "doi:10.1038/s41598-023-41032-5" ;
    fair2r:verificationState verif:ai-confirmed .

src:magesh2024legal  a fair2r:Source ;
    dcterms:title "Hallucination-Free? Assessing the Reliability of Leading AI Legal Research Tools"@en ;
    fair2r:verificationState verif:ai-confirmed .

# Section entities
ent:section-self          a fair2r:Section ; rdfs:label "This Paper, Generated by this Process"@en ;
    prov:hadPrimarySource ent:manuscript .
ent:section-evolution     a fair2r:Section ; rdfs:label "Process Evolution During Cooperative Writing"@en ;
    prov:hadPrimarySource ent:manuscript .
ent:section-eight         a fair2r:Section ; rdfs:label "Eight Integrated Practices"@en ;
    prov:hadPrimarySource ent:manuscript .
ent:section-failure-modes a fair2r:Section ; rdfs:label "Failure Modes Named and Addressed"@en ;
    prov:hadPrimarySource ent:manuscript .

# Authoring activity for the first-draft pass
act:author-first-draft  a fair2r:AuthoringPass ;
    rdfs:label "Draft the long-form manuscript from the source repository"@en ;
    prov:startedAtTime "2026-05-06T00:00:00Z"^^xsd:dateTime ;
    prov:endedAtTime   "2026-05-06T00:00:00Z"^^xsd:dateTime ;
    prov:wasAssociatedWith agent:scientific-writer ;
    prov:wasAssociatedWith agent:claude-opus-4-7 ;
    prov:qualifiedAssociation [
        a prov:Association ;
