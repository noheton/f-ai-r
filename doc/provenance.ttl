#-------------------------------------------------------------------------
# §3.6 Looking forward: provenance graphs as research infrastructure
#-------------------------------------------------------------------------

src:ashburner2000go            a fair2r:Source ;
    dcterms:title "Gene Ontology: tool for the unification of biology"@en ;
    dcterms:identifier "doi:10.1038/75556" ;
    fair2r:verificationState verif:lit-retrieved .

ent:section-pattern-research-infrastructure  a fair2r:Section ;
    rdfs:label "Looking forward: provenance graphs as research infrastructure"@en ;
    prov:hadPrimarySource ent:manuscript .

claim:bioinformatics-precedent  a fair2r:Claim ;
    rdfs:label "Bioinformatics standardised semantic tagging (Gene Ontology and successors) under data-volume pressure; the ontology was not a research output but a precondition for research that scaled, and that investment is what made the next decade of bioinformatics possible."@en ;
    prov:wasAttributedTo agent:human-author ;
    prov:wasDerivedFrom  src:ashburner2000go ;
    fair2r:verificationState verif:human-confirmed ;
    dcterms:created "2026-05-06"^^xsd:date .

claim:future-research-infrastructure  a fair2r:Claim ;
    rdfs:label "Future research success may depend less on the solitary craft of a single manuscript and more on (i) provenance models that turn published claims into machine-readable hypotheses; (ii) graph interconnectivity across institutional knowledge graphs (the Helmholtz cross-centre graph as the proximate example); (iii) clever experimental validation that uses the graph to identify the next testable deviation from the published consensus."@en ;
    prov:wasAttributedTo agent:human-author ;
    prov:wasDerivedFrom  src:ashburner2000go , src:curdt2025hmc ;
    fair2r:verificationState verif:human-confirmed ;
    dcterms:created "2026-05-06"^^xsd:date .

act:rev-research-infrastructure  a prov:Activity ;
    rdfs:label "Add §3.6 'Looking forward: provenance graphs as research infrastructure' to pattern.tex"@en ;
    prov:startedAtTime "2026-05-06T00:00:00Z"^^xsd:dateTime ;
    prov:endedAtTime   "2026-05-06T00:00:00Z"^^xsd:dateTime ;
