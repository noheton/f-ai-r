claim:reproducibility-baseline-poor  a fair2r:Claim ;
    rdfs:label "The LLM-assisted writing failure modes sit on top of a reproducibility baseline that is already poor in many fields, so an authoring-side discipline is necessary even before LLMs are considered."@en ;
    prov:wasAttributedTo agent:human-author ;
    prov:wasDerivedFrom  src:ioannidis2005 , src:pineau2021reproducibility ;
    fair2r:verificationState verif:ai-confirmed ;
    dcterms:created "2026-05-06"^^xsd:date .

claim:reviewer-side-ai-policies  a fair2r:Claim ;
    rdfs:label "Major ML venues (NeurIPS, ICLR, ACL Rolling Review) have published explicit author-and-reviewer AI policies, going beyond the editorial-level disclosure norms of the medical journals."@en ;
    prov:wasAttributedTo agent:human-author ;
    prov:wasDerivedFrom  src:neurips_llm_policy , src:iclr_llm_policy , src:aclrr_llm_policy ;
    fair2r:verificationState verif:ai-confirmed ;
    dcterms:created "2026-05-06"^^xsd:date .

hc:gap-fill-reproducibility-and-policies  a fair2r:HumanContribution ;
    rdfs:label "Researcher request: link reviewer-side AI policies + reproducibility-crisis literature"@en ;
    fair2r:contributedBy agent:human-author ;
    fair2r:contributionType "content-prompt" ;
    fair2r:contributionLeverage "medium" ;
    rdfs:comment "Researcher endorsed two of the three small gaps the model had flagged: reviewer-side AI policies (NeurIPS / ICLR / ACL ARR) and reproducibility-crisis literature (Ioannidis 2005; Pineau et al. 2021). Five new bib entries; citations inserted in intro.tex (reproducibility) and background.tex (reviewer-AI policies). The third flagged gap (position-paper genre precedents) was not endorsed and is not added in this commit."@en ;
    dcterms:created "2026-05-06"^^xsd:date ;
    prov:influenced claim:reproducibility-baseline-poor , claim:reviewer-side-ai-policies .

