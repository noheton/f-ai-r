    dcterms:title "Improving Reproducibility in Machine Learning Research (NeurIPS 2019)"@en ;
    dcterms:identifier <https://jmlr.org/papers/v22/20-303.html> ;
    fair2r:verificationState verif:ai-confirmed .

src:neurips_llm_policy         a fair2r:Source ;
    dcterms:title "NeurIPS policy on the use of Large Language Models"@en ;
